# Copy to .env.production and fill all values
NODE_ENV=production
PORT=5000

# Domain setup
MAIN_DOMAIN=rioassetmanagement.net
FRONTEND_URL=https://web.rioassetmanagement.net
BACKEND_URL=https://web.rioassetmanagement.net
API_BASE_URL=https://web.rioassetmanagement.net/api

# Required app secrets/infra
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DB_NAME
JWT_SECRET=replace-with-strong-secret

# Redis — Docker Compose service name (alm-redis → hostname alm_redis)
CACHE_ENABLED=true
REDIS_URL=redis://alm_redis:6379/0
AUTH_CACHE_TTL_MS=120000
TENANT_EXISTS_CACHE_TTL_MS=300000
DASHBOARD_CACHE_TTL_MS=180000
ASSETS_LIST_CACHE_TTL_MS=120000
ASSIGNMENT_CACHE_TTL_MS=180000
SCRAP_APPROVAL_CACHE_TTL_MS=180000
MAINTENANCE_SUPERVISOR_CACHE_TTL_MS=180000

# Database pools — single Docker container (one Node process)
DB_POOL_MAX=20
DB_POOL_MIN=2
TENANT_REGISTRY_POOL_MAX=10
TENANT_DB_POOL_MAX=5

# Behind nginx on host (proxy to container port 5002)
TRUST_PROXY=true
TRUST_PROXY_HOPS=1

# Rate limiting (per client IP)
RATE_LIMIT_MAX_PER_MIN=300
AUTH_RATE_LIMIT_MAX_PER_15MIN=30

